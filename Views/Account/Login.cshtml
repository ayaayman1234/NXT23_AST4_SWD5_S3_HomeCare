@model NursingCarePlatform.Web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<!-- 
   Premium Responsive Login Layout
   - Padded container to avoid navbar overlaps
   - Flat rounded mockup design
   - Uses premium_nurse.png on left
-->
<div class="container" style="padding-top: 40px; padding-bottom: 80px;">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="background: #ffffff;">
                <div class="row g-0">
                    
                    <!-- Left Side - High Quality Graphic -->
                    <div class="col-lg-6 d-none d-lg-block position-relative">
                        <img src="~/images/premium_nurse.png"
                             class="w-100 h-100"
                             style="object-fit: cover; min-height: 580px;"
                             alt="Healthcare nurse with tablet" />
                        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(15,118,110,0.85), rgba(12,74,110,0.45));"></div>
                        <div class="position-absolute bottom-0 start-0 p-5 text-white">
                            <h3 class="fw-bold mb-2"><i class="bi bi-heart-pulse-fill me-2 text-info"></i>NursingCare</h3>
                            <p class="mb-0 text-white-50 small">Connecting patients with verified, professional home nurses.</p>
                        </div>
                    </div>
                    
                    <!-- Right Side - Interactive Form -->
                    <div class="col-lg-6">
                        <div class="p-4 p-sm-5 d-flex flex-column justify-content-center h-100">
                            
                            <div class="text-center mb-4">
                                <div class="mx-auto rounded-circle d-flex align-items-center justify-content-center bg-light" style="width: 70px; height: 70px;">
                                    <i class="bi bi-shield-lock-fill text-primary fs-3"></i>
                                </div>
                                <h3 class="fw-bold mt-3 mb-1">Welcome Back</h3>
                                <p class="text-muted small">Access your account dashboard securely</p>
                            </div>

                            <form asp-action="Login" method="post" class="needs-validation" novalidate>
                                @Html.AntiForgeryToken()

                                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small border-0 mb-3"></div>

                                <!-- Email Field -->
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold small text-secondary">Email Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                        <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="name@domain.com" required />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <!-- Password Field -->
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label fw-semibold small text-secondary">Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                        <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" required />
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <!-- Remember Me -->
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div class="form-check form-switch m-0">
                                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                        <label asp-for="RememberMe" class="form-check-label small text-secondary">Keep me signed in</label>
                                    </div>
                                </div>

                                <!-- Submit Button -->
                                <button type="submit" class="nc-btn-primary w-100 justify-content-center text-center py-3 mb-3">
                                    Sign In <i class="bi bi-box-arrow-in-right ms-2 fs-5"></i>
                                </button>
                            </form>

                            <hr class="my-4 text-muted opacity-25" />

                            <div class="text-center">
                                <span class="text-muted small">Don't have an account yet?</span>
                                <a asp-action="Register" class="fw-bold text-primary text-decoration-none small ms-1">Create Account</a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}