@model NursingCarePlatform.Web.ViewModels.Rating.CreateRatingViewModel

@{
    ViewData["Title"] = "Rate Nurse";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow-lg">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        <i class="bi bi-star-fill"></i>
                        Rate Nurse
                    </h3>

                </div>

                <div class="card-body">

                    <form asp-action="Create" method="post">

                        <input asp-for="CareRequestId" type="hidden" />

                        <input asp-for="NurseId" type="hidden" />

                        <div class="mb-4">

                            <label asp-for="Stars"
                                   class="form-label fw-bold">
                                Rating
                            </label>

                            <select asp-for="Stars"
                                    class="form-select">

                                <option value="">Choose Rating</option>

                                <option value="5">⭐⭐⭐⭐⭐ Excellent</option>

                                <option value="4">⭐⭐⭐⭐ Very Good</option>

                                <option value="3">⭐⭐⭐ Good</option>

                                <option value="2">⭐⭐ Fair</option>

                                <option value="1">⭐ Poor</option>

                            </select>

                            <span asp-validation-for="Stars"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Comment"
                                   class="form-label fw-bold">
                                Comment
                            </label>

                            <textarea asp-for="Comment"
                                      rows="5"
                                      class="form-control"
                                      placeholder="Write your feedback..."></textarea>

                            <span asp-validation-for="Comment"
                                  class="text-danger"></span>

                        </div>

                        <button type="submit"
                                class="btn btn-success">

                            <i class="bi bi-star-fill"></i>

                            Submit Rating

                        </button>

                        <a asp-controller="Patient"
                               asp-action="MyRequests"
                               class="btn btn-secondary">

                            Cancel

                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}