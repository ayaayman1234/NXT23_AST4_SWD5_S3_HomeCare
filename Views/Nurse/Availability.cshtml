@model IEnumerable<NursingCarePlatform.Web.Models.Availability>

@{
    ViewData["Title"] = "My Availability";
}

<!-- FullCalendar CDN -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet" />

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-calendar-week text-success me-2"></i>My Work Schedule
        </h2>
        <a asp-action="AddAvailability" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Add Availability Slot
        </a>
    </div>



    <div class="row g-4">
        <!-- Availability List Table -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-list-task me-2"></i> Scheduled Slots
                </div>
                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="alert alert-info border-0 rounded-0 m-0 py-4 text-center">
                            <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                            No availability has been added yet. Click "Add Availability" to build your schedule.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Day of Week</th>
                                        <th>Hours</th>
                                        <th width="100" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="fw-semibold">
                                                <i class="bi bi-calendar-day text-success me-1"></i> @item.Day
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="DeleteAvailability" asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-outline-danger"
                                                   onclick="return confirm('Remove this availability slot?')">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Interactive FullCalendar -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-calendar-event me-2"></i> Interactive Weekly Calendar View
                </div>
                <div class="card-body p-3">
                    <div id="calendar" style="height: 480px;"></div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            
            // Map Day names to daysOfWeek array for FullCalendar recurring events
            // Sunday = 0, Monday = 1, etc.
            var events = [
                @foreach (var item in Model)
                {
                    var dayNum = item.Day.ToLower() switch
                    {
                        "sunday" => 0,
                        "monday" => 1,
                        "tuesday" => 2,
                        "wednesday" => 3,
                        "thursday" => 4,
                        "friday" => 5,
                        "saturday" => 6,
                        _ => 1
                    };
                    <text>{
                        title: 'Work Slot',
                        daysOfWeek: [@dayNum],
                        startTime: '@item.StartTime.ToString(@"hh\:mm")',
                        endTime: '@item.EndTime.ToString(@"hh\:mm")',
                        display: 'block',
                        backgroundColor: '#198754',
                        borderColor: '#157347',
                        textColor: '#ffffff'
                    },</text>
                }
            ];

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                headerToolbar: {
                    left: '',
                    center: 'title',
                    right: ''
                },
                allDaySlot: false,
                dayHeaderFormat: { weekday: 'short' },
                slotMinTime: '06:00:00', // Set operational window
                slotMaxTime: '22:00:00',
                events: events,
                height: 'auto',
                firstDay: 6, // Start week on Saturday (standard in Egypt/Middle East)
                themeSystem: 'bootstrap5'
            });
            
            calendar.render();
        });
    </script>
}