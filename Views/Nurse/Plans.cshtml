@model List<NursingCarePlatform.Web.ViewModels.Admin.AdminSubscriptionPlanViewModel>

@{
    ViewData["Title"] = "Subscription Plans";
    var activePlanId = ViewBag.ActivePlanId as int?;
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-dark">Choose Your <span class="text-success">Success Plan</span></h1>
        <p class="lead text-muted">Upgrade your plan to reduce commission rates and boost your earnings!</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-3 mb-3 text-center justify-content-center">
        @foreach (var plan in Model)
        {
            var isCurrent = activePlanId == plan.Id;
            var isFree = plan.MonthlyFee == 0;
            var borderClass = isCurrent ? "border-success" : "border-light";
            var headerBg = isCurrent ? "bg-success text-white" : "bg-light";

            <div class="col-lg-4 mb-4">
                <div class="card mb-4 rounded-3 shadow-sm h-100 @borderClass" style="transition: transform 0.3s;">
                    @if (isCurrent)
                    {
                        <div class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-warning text-dark px-3 py-2" style="font-size: 0.9rem;">
                            <i class="bi bi-star-fill me-1"></i> Current Plan
                        </div>
                    }
                    <div class="card-header py-3 @headerBg">
                        <h4 class="my-0 fw-normal">@plan.Name</h4>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h1 class="card-title pricing-card-title mt-2">
                            @(isFree ? "Free" : plan.MonthlyFee.ToString("N0") + " EGP")
                            <small class="text-muted fw-light">/mo</small>
                        </h1>
                        <p class="text-muted mt-3 mb-4 flex-grow-1" style="min-height: 48px;">
                            @plan.Description
                        </p>
                        <ul class="list-unstyled mt-3 mb-4 text-start bg-light p-3 rounded">
                            <li class="mb-2">
                                <i class="bi bi-check2 text-success fw-bold me-2"></i>
                                Platform Commission: <strong>@((plan.CommissionRate * 100).ToString("0.#"))%</strong>
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check2 text-success fw-bold me-2"></i>
                                Unlimited Job Proposals
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check2 text-success fw-bold me-2"></i>
                                24/7 Premium Support
                            </li>
                        </ul>
                        
                        <form asp-action="SubscribeToPlan" method="post" class="mt-auto">
                            <input type="hidden" name="planId" value="@plan.Id" />
                            @if (isCurrent)
                            {
                                <button type="button" class="w-100 btn btn-lg btn-outline-success" disabled>
                                    Active
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="w-100 btn btn-lg btn-success" onclick="return confirm('Are you sure you want to subscribe to @plan.Name?');">
                                    Subscribe Now
                                </button>
                            }
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
</style>
