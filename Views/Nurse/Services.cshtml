@model IEnumerable<NursingCarePlatform.Web.ViewModels.Nurse.NurseServiceViewModel>

@{
    ViewData["Title"] = "My Services";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            <i class="bi bi-heart-pulse"></i>
            My Services
        </h2>

        <a asp-action="AddService" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Add Service
        </a>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You haven't added any services yet.
        </div>
    }
    else
    {
        <div class="card shadow">

            <div class="card-body p-0">

                <table class="table table-hover table-striped mb-0">

                    <thead class="table-dark">

                        <tr>

                            <th>Category</th>

                            <th>Service</th>

                            <th>Price</th>

                            <th width="150">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.CategoryName</td>

                                <td>@item.ServiceName</td>

                                <td>@item.Price.ToString("0.##") EGP</td>

                                <td>

                                    <a asp-action="DeleteService"
                                           asp-route-serviceId="@item.ServiceId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete this service?')">

                                        <i class="bi bi-trash"></i>

                                        Delete

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

</div>