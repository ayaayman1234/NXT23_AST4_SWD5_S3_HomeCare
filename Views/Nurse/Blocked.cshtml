@{
    ViewData["Title"] = "Account Suspended";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6 text-center">
        <div class="card shadow border-0 py-5 px-4 rounded-3 border-top border-5 border-danger">
            <div class="card-body">
                <div class="mb-4">
                    <div class="bg-danger-subtle rounded-circle d-inline-flex align-items-center justify-content-center text-danger mx-auto"
                         style="width: 100px; height: 100px; font-size: 50px;">
                        <i class="bi bi-slash-circle-fill"></i>
                    </div>
                </div>
                
                <h2 class="fw-bold text-danger mb-3">Account Suspended</h2>
                <h5 class="text-muted mb-4">Your nurse account has been blocked by the system administrator.</h5>
                
                <div class="alert alert-warning text-start border-0 py-3 mb-4">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Your profile will no longer be visible to patients and you cannot accept any new care requests. Please contact support at <strong>support@homecare.com</strong> to appeal.
                </div>

                <div class="d-flex justify-content-center gap-2">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4 py-2 fw-semibold">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign Out
                        </button>
                    </form>
                    <a href="/" class="btn btn-secondary rounded-pill px-4 py-2 fw-semibold">
                        <i class="bi bi-house-door me-1"></i> Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
