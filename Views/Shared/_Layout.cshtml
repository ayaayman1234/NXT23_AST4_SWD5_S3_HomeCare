@using NursingCarePlatform.Web.Models
@using NursingCarePlatform.Web.Services.Interfaces
@using Microsoft.AspNetCore.Identity

@inject INotificationService NotificationService
@inject UserManager<ApplicationUser> UserManager

@{
    int unreadCount = 0;

    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var currentUser = await UserManager.GetUserAsync(User);

        if (currentUser != null)
        {
            var notifications = await NotificationService.GetUserNotificationsAsync(currentUser.Id);

            unreadCount = notifications.Count(n => !n.IsRead);
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - HomeCare</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">

        <div class="container">

            <a class="navbar-brand fw-bold"
                   asp-controller="Home"
                   asp-action="Index">

                <i class="bi bi-heart-pulse-fill"></i>

                HomeCare

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbarNav">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">

                        <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                            Home

                        </a>

                    </li>

                </ul>

                <ul class="navbar-nav align-items-center">

                    @if (User.Identity!.IsAuthenticated)
                    {
                        @if (User.IsInRole("Patient"))
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                       asp-controller="Patient"
                                       asp-action="Dashboard">

                                    Dashboard

                                </a>

                            </li>
                        }

                        @if (User.IsInRole("Nurse"))
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                       asp-controller="Nurse"
                                       asp-action="Dashboard">

                                    Dashboard

                                </a>

                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                       asp-controller="Admin"
                                       asp-action="Dashboard">

                                    Dashboard

                                </a>

                            </li>
                        }

                        <!-- Notification Bell -->

                        <li class="nav-item">

                            <a class="nav-link position-relative"
                                   asp-controller="Notification"
                                   asp-action="Index">

                                <i class="bi bi-bell fs-5"></i>

                                @if (unreadCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">

                                        @unreadCount

                                    </span>
                                }

                            </a>

                        </li>

                        <!-- Logout -->

                        <li class="nav-item ms-2">

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post">

                                <button class="btn btn-outline-light">

                                    Logout

                                </button>

                            </form>

                        </li>
                    }
                    else
                    {
                        <li class="nav-item">

                            <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">

                                Login

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="btn btn-light ms-2"
                                   asp-controller="Account"
                                   asp-action="Register">

                                Register

                            </a>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <main class="container mt-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">

                @TempData["Success"]

            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">

                @TempData["Error"]

            </div>
        }

        @RenderBody()

    </main>

    <footer class="bg-dark text-white mt-5">

        <div class="container text-center py-4">

            <h5>HomeCare Platform</h5>

            <p>

                Connecting Patients with Professional Nurses.

            </p>

            <small>

                © @DateTime.Now.Year HomeCare. All Rights Reserved.

            </small>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>