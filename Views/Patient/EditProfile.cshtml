@model NursingCarePlatform.Web.ViewModels.Patient.EditPatientViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-5">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <h3>Edit Profile</h3>

        </div>

        <div class="card-body">

            <form asp-action="EditProfile" method="post">

                <input asp-for="Id" type="hidden" />
                <input asp-for="UserId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber"></label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">

                        <label asp-for="Gender"></label>

                        <select asp-for="Gender" class="form-select">

                            <option>Male</option>
                            <option>Female</option>

                        </select>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label asp-for="Age"></label>

                        <input asp-for="Age" class="form-control" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label asp-for="BloodType"></label>

                        <select asp-for="BloodType" class="form-select">

                            <option value="">Select Blood Type</option>

                            <option>A+</option>
                            <option>A-</option>
                            <option>B+</option>
                            <option>B-</option>
                            <option>AB+</option>
                            <option>AB-</option>
                            <option>O+</option>
                            <option>O-</option>

                        </select>

                    </div>

                </div>

                <div class="mb-3">

                    <label asp-for="Address"></label>

                    <input asp-for="Address" class="form-control" />

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="City"></label>

                        <input asp-for="City" class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="Governorate"></label>

                        <input asp-for="Governorate" class="form-control" />

                    </div>

                </div>

                <div class="mb-3">

                    <label asp-for="MedicalHistory"></label>

                    <textarea asp-for="MedicalHistory"
                              rows="5"
                              class="form-control"></textarea>

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    Save Changes

                </button>

                <a asp-action="Profile"
                       class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}