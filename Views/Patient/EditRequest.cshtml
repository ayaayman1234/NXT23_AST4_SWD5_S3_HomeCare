@model NursingCarePlatform.Web.ViewModels.CareRequest.EditCareRequestViewModel

@{
    ViewData["Title"] = "Edit Care Request";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-header bg-warning">

                    <h4 class="mb-0">

                        <i class="bi bi-pencil-square"></i>

                        Edit Care Request

                    </h4>

                </div>

                <div class="card-body">

                    <form asp-action="EditRequest" method="post">

                        <input asp-for="Id" type="hidden" />
                        <input asp-for="PatientId" type="hidden" />

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-3">

                            <label asp-for="ServiceId" class="form-label"></label>

                            <select asp-for="ServiceId"
                                    asp-items="Model.Services"
                                    class="form-select">

                                <option value="">-- Select Service --</option>

                            </select>

                            <span asp-validation-for="ServiceId"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Address"
                                   class="form-label"></label>

                            <input asp-for="Address"
                                   class="form-control" />

                            <span asp-validation-for="Address"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Description"
                                   class="form-label"></label>

                            <textarea asp-for="Description"
                                      rows="4"
                                      class="form-control"></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="PreferredDate"
                                   class="form-label"></label>

                            <input asp-for="PreferredDate"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="PreferredDate"
                                  class="text-danger"></span>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label asp-for="BudgetMin"
                                       class="form-label"></label>

                                <input asp-for="BudgetMin"
                                       class="form-control" />

                            </div>

                            <div class="col-md-6 mb-3">

                                <label asp-for="BudgetMax"
                                       class="form-label"></label>

                                <input asp-for="BudgetMax"
                                       class="form-control" />

                            </div>

                        </div>

                        <button class="btn btn-warning w-100">

                            <i class="bi bi-save"></i>

                            Save Changes

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}