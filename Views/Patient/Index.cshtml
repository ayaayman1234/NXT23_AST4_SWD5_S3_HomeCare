@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container py-5">

    <div class="row mb-5">

        <div class="col-lg-12">

            <div class="bg-primary text-white rounded-4 p-5 shadow">

                <h2 class="fw-bold">

                    Welcome to Patient Dashboard

                </h2>

                <p class="mb-0">

                    Manage your profile, medical history, and care requests from one place.

                </p>

            </div>

        </div>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card service-card text-center p-4 h-100">

                <i class="bi bi-person-circle service-icon"></i>

                <h4 class="mt-3">

                    My Profile

                </h4>

                <p>

                    View your personal information.

                </p>

                <a asp-action="Details"
                       class="btn btn-primary">

                    View Profile

                </a>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card service-card text-center p-4 h-100">

                <i class="bi bi-pencil-square service-icon"></i>

                <h4 class="mt-3">

                    Edit Profile

                </h4>

                <p>

                    Update your medical history.

                </p>

                <a asp-action="Edit"
                       class="btn btn-success">

                    Edit

                </a>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card service-card text-center p-4 h-100">

                <i class="bi bi-heart-pulse service-icon"></i>

                <h4 class="mt-3">

                    HomeCare

                </h4>

                <p>

                    Receive professional healthcare services from qualified nurses.

                </p>

                <a asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-outline-primary">

                    Home

                </a>

            </div>

        </div>

    </div>

</div>