@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container-fluid">

    <div class="row mb-4">

        <div class="col">

            <h2 class="fw-bold">
                Patient Dashboard
            </h2>

            <p class="text-muted">
                Welcome back to Nursing Care Platform.
            </p>

        </div>

    </div>

    <div class="row g-4">

        <div class="col-lg-3">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <i class="fa-solid fa-user fa-3x text-primary mb-3"></i>

                    <h5>My Profile</h5>

                    <p class="text-muted">
                        View your personal information.
                    </p>

                    <a asp-action="Details"
                           class="btn btn-primary w-100">

                        Open

                    </a>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <i class="fa-solid fa-pen-to-square fa-3x text-success mb-3"></i>

                    <h5>Edit Profile</h5>

                    <p class="text-muted">
                        Update your information.
                    </p>

                    <a asp-action="Edit"
                           class="btn btn-success w-100">

                        Edit

                    </a>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <i class="fa-solid fa-notes-medical fa-3x text-danger mb-3"></i>

                    <h5>Medical History</h5>

                    <p class="text-muted">
                        Review your medical records.
                    </p>

                    <a asp-action="Details"
                           class="btn btn-danger w-100">

                        View

                    </a>

                </div>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <i class="fa-solid fa-hand-holding-heart fa-3x text-warning mb-3"></i>

                    <h5>Care Requests</h5>

                    <p class="text-muted">
                        Manage your nursing requests.
                    </p>

                    <button class="btn btn-warning w-100">

                        Coming Soon

                    </button>

                </div>

            </div>

        </div>

    </div>

</div>