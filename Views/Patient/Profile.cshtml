@model NursingCarePlatform.Web.Models.Patient

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        <i class="bi bi-person-circle"></i>
                        My Profile
                    </h3>

                </div>

                <div class="card-body">

                    

                    <div class="text-center mb-4">

                        @if (!string.IsNullOrEmpty(Model.User.ProfilePhoto))
                        {
                            <img src="@Model.User.ProfilePhoto"
                                 class="rounded-circle border shadow"
                                 width="130"
                                 height="130"
                                 style="object-fit:cover;" />
                        }
                        else
                        {
                            <i class="bi bi-person-circle text-primary"
                               style="font-size:120px;"></i>
                        }

                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">First Name</div>
                        <div class="col-md-8">@Model.User.FirstName</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Last Name</div>
                        <div class="col-md-8">@Model.User.LastName</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Email</div>
                        <div class="col-md-8">@Model.User.Email</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Phone Number</div>
                        <div class="col-md-8">@Model.User.PhoneNumber</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Gender</div>
                        <div class="col-md-8">@Model.User.Gender</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Age</div>
                        <div class="col-md-8">@Model.User.Age</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Address</div>
                        <div class="col-md-8">@Model.User.Address</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">City</div>
                        <div class="col-md-8">@Model.User.City</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Governorate</div>
                        <div class="col-md-8">@Model.User.Governorate</div>
                    </div>

                    <hr />
                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Blood Type

                        </div>

                        <div class="col-md-8">

                            @if (string.IsNullOrWhiteSpace(Model.BloodType))
                            {
                                <span class="text-muted">
                                    Not specified
                                </span>
                            }
                            else
                            {
                                @Model.BloodType
                            }

                        </div>

                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4 fw-bold">Medical History</div>

                        <div class="col-md-8">

                            @if (string.IsNullOrWhiteSpace(Model.MedicalHistory))
                            {
                                <span class="text-muted">
                                    No medical history added.
                                </span>
                            }
                            else
                            {
                                @Model.MedicalHistory
                            }

                        </div>

                    </div>

                    <div class="d-flex gap-2">

                        <a asp-action="EditProfile"
                               class="btn btn-primary">

                            <i class="bi bi-pencil-square"></i>

                            Edit Profile

                        </a>

                        <a asp-action="Dashboard"
                               class="btn btn-secondary">

                            <i class="bi bi-arrow-left"></i>

                            Back

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>