@model IEnumerable<NursingCarePlatform.Web.Models.CareRequest>

@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container py-5">

    <div class="mb-5">

        <h2 class="fw-bold text-primary">
            Welcome 👋
        </h2>

        <p class="text-muted">
            Manage your care requests and account from one place.
        </p>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <!-- Dashboard Cards -->

    <div class="row mb-5">

        <div class="col-md-3 mb-3">

            <a asp-action="MyRequests"
                   class="text-decoration-none">

                <div class="card dashboard-card shadow text-center h-100 border-0">

                    <div class="card-body">

                        <i class="bi bi-clipboard2-check display-5 text-primary"></i>

                        <h5 class="mt-3">My Requests</h5>

                        <p class="text-muted mb-0">
                            @Model.Count() Requests
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-3 mb-3">

            <a asp-action="CreateCareRequest"
                   class="text-decoration-none">

                <div class="card dashboard-card shadow text-center h-100 border-0">

                    <div class="card-body">

                        <i class="bi bi-plus-circle display-5 text-success"></i>

                        <h5 class="mt-3">Create Request</h5>

                        <p class="text-muted mb-0">
                            Request Nursing Care
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-3 mb-3">

            <a asp-action="Profile"
                   class="text-decoration-none">

                <div class="card dashboard-card shadow text-center h-100 border-0">

                    <div class="card-body">

                        <i class="bi bi-person-circle display-5 text-info"></i>

                        <h5 class="mt-3">Profile</h5>

                        <p class="text-muted mb-0">
                            View & Edit Profile
                        </p>

                    </div>

                </div>

            </a>

        </div>

        

    </div>

    <!-- Recent Requests -->

    <h3 class="fw-bold mb-4">
        Recent Requests
    </h3>

    @if (!Model.Any())
    {
        <div class="card shadow-sm">

            <div class="card-body text-center py-5">

                <i class="bi bi-clipboard2-pulse display-3 text-secondary"></i>

                <h4 class="mt-3">
                    No Care Requests Yet
                </h4>

                <p class="text-muted">
                    Create your first request to find a qualified nurse.
                </p>

            </div>

        </div>
    }
    else
    {
        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body">

                            <h5 class="card-title">
                                @item.Description
                            </h5>

                            <p>
                                <strong>Address:</strong>
                                @item.Address
                            </p>

                            <p>
                                <strong>Date:</strong>
                                @item.PreferredDate.ToShortDateString()
                            </p>

                            <p>
                                <strong>Status:</strong>

                                <span class="badge bg-primary">
                                    @item.RequestStatus
                                </span>
                            </p>

                            <p>
                                <strong>Budget:</strong>
                                @item.BudgetMin -
                                @item.BudgetMax EGP
                            </p>

                        </div>

                        <div class="card-footer bg-white">

                            <a asp-action="RequestDetails"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm">
                                Details
                            </a>

                            <a asp-action="EditRequest"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="DeleteRequest"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>