@model NursingCarePlatform.Web.Models.Patient

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-primary text-white text-center py-4">

                    <h2 class="mb-0">

                        Patient Profile

                    </h2>

                </div>

                <div class="card-body p-5">

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Full Name

                        </div>

                        <div class="col-md-8">

                            @Model.User.FirstName @Model.User.LastName

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Email

                        </div>

                        <div class="col-md-8">

                            @Model.User.Email

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Phone

                        </div>

                        <div class="col-md-8">

                            @Model.User.PhoneNumber

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Address

                        </div>

                        <div class="col-md-8">

                            @Model.User.Address

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            City

                        </div>

                        <div class="col-md-8">

                            @Model.User.City

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Governorate

                        </div>

                        <div class="col-md-8">

                            @Model.User.Governorate

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Gender

                        </div>

                        <div class="col-md-8">

                            @Model.User.Gender

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4 fw-bold">

                            Age

                        </div>

                        <div class="col-md-8">

                            @Model.User.Age

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-4">

                        <div class="col-md-4 fw-bold">

                            Medical History

                        </div>

                        <div class="col-md-8">

                            @(string.IsNullOrWhiteSpace(Model.MedicalHistory)
                                ? "No medical history."
                                : Model.MedicalHistory)

                        </div>

                    </div>

                    <div class="text-center">

                        <a asp-action="Edit"
                               class="btn btn-success me-2">

                            <i class="bi bi-pencil-square"></i>

                            Edit Profile

                        </a>

                        <a asp-action="Index"
                               class="btn btn-secondary">

                            Back

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>