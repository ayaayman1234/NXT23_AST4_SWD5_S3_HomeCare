@*@* ==================== Views/Payment/Create.cshtml ==================== *@
@model NursingCarePlatform.Web.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Create Payment";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">New Payment</h4>
        </div>
        <div class="card-body">
            <form asp-controller="Payment" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="CareRequestId" class="form-label"></label>
                    <input asp-for="CareRequestId" class="form-control" />
                    <span asp-validation-for="CareRequestId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Amount" class="form-label"></label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PaymentMethod" class="form-label"></label>
                    <select asp-for="PaymentMethod" class="form-select">
                        <option value="CreditCard">Credit Card</option>
                        <option value="Cash">Cash</option>
                        <option value="Wallet">Digital Wallet</option>
                    </select>
                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TransactionReference" class="form-label"></label>
                    <input asp-for="TransactionReference" class="form-control" />
                    <span asp-validation-for="TransactionReference" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Submit Payment</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}