@model NursingCarePlatform.Web.ViewModels.RecurringRequest.CreateRecurringRequestViewModel

@{
    ViewData["Title"] = "Create Recurring Request";
}

<h2>Create Recurring Request</h2>

<form asp-action="Create" method="post">

    <input asp-for="CareRequestId" type="hidden" />

    <div class="mb-3">
        <label asp-for="RepetitionCount" class="form-label"></label>
        <input asp-for="RepetitionCount" class="form-control" />
        <span asp-validation-for="RepetitionCount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FrequencyInterval" class="form-label"></label>
        <input asp-for="FrequencyInterval" class="form-control" />
        <small class="text-muted">
            Number of days between each request
        </small>
        <span asp-validation-for="FrequencyInterval" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>

    <button class="btn btn-success">
        Save
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}