@model NursingCarePlatform.Web.ViewModels.NursingNote.CreateNursingNoteViewModel

@{
    ViewData["Title"] = "Add Nursing Note";
}

<div class="container py-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                <i class="bi bi-journal-medical"></i>
                Add Nursing Note
            </h3>

        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <input asp-for="AssignmentId" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="BloodPressure" class="form-label"></label>

                    <input asp-for="BloodPressure"
                           class="form-control"
                           placeholder="120/80" />

                    <span asp-validation-for="BloodPressure"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="GlucoseLevel" class="form-label"></label>

                    <input asp-for="GlucoseLevel"
                           class="form-control" />

                    <span asp-validation-for="GlucoseLevel"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Temperature" class="form-label"></label>

                    <input asp-for="Temperature"
                           class="form-control" />

                    <span asp-validation-for="Temperature"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Notes" class="form-label"></label>

                    <textarea asp-for="Notes"
                              rows="5"
                                  class="form-control">
                    </textarea>

                        <span asp-validation-for="Notes"
                              class="text-danger">
                        </span>

                    </div>

                    <button type="submit"
                            class="btn btn-success">

                        <i class="bi bi-check-circle"></i>

                        Save Note

                    </button>

                    <a asp-controller="Assignment"
                           asp-action="MyAssignments"
                           class="btn btn-secondary">

                        Cancel

                    </a>

                </form>

            </div>

        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }