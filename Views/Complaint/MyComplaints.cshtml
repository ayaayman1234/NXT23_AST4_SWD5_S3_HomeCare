@model IEnumerable<NursingCarePlatform.Web.ViewModels.Complaint.ComplaintHistoryViewModel>

@{
    ViewData["Title"] = "My Complaints";
}

<div class="container py-5" style="max-width: 1000px;">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-extrabold text-dark mb-1">
                <i class="bi bi-chat-left-dots-fill text-danger me-2"></i>
                My Complaints
            </h2>
            <p class="text-muted mb-0 small">Track and view the resolution status of reports you have filed.</p>
        </div>
        <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill px-4 btn-sm fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Dashboard
        </a>
    </div>

    @if (!Model.Any())
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm py-5 text-center" style="border-radius: 20px;">
            <div class="card-body">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center text-muted mb-3" style="width: 80px; height: 80px; font-size: 36px;">
                    <i class="bi bi-chat-square-heart text-success"></i>
                </div>
                <h4 class="fw-bold">No Complaints Filed</h4>
                <p class="text-muted mx-auto" style="max-width: 420px;">
                    Excellent! You haven't filed any complaints against any nurses. We are glad you're having a smooth experience on our platform.
                </p>
            </div>
        </div>
    }
    else
    {
        <!-- Complaints List Card -->
        <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-0">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase text-secondary small fw-bold" style="font-size: 0.75rem;">Title</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold" style="font-size: 0.75rem;">Against Nurse</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold" style="font-size: 0.75rem;">Status</th>
                            <th class="py-3 text-uppercase text-secondary small fw-bold" style="font-size: 0.75rem;">Date Filed</th>
                            <th class="pe-4 py-3 text-end" style="width: 120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark">@item.Title</div>
                                </td>
                                <td class="py-3 text-secondary">
                                    <i class="bi bi-person me-1"></i> @item.Against
                                </td>
                                <td class="py-3">
                                    @if (item.Status == "Open" || item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill fw-semibold" style="font-size: 0.75rem;">
                                            <i class="bi bi-hourglass-split me-1"></i> Open
                                        </span>
                                    }
                                    else if (item.Status == "Resolved")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-semibold" style="font-size: 0.75rem;">
                                            <i class="bi bi-check-circle-fill me-1"></i> Resolved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-semibold" style="font-size: 0.75rem;">
                                            <i class="bi bi-x-circle-fill me-1"></i> @item.Status
                                        </span>
                                    }
                                </td>
                                <td class="py-3 text-secondary small">
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <style>
        .fw-extrabold { font-weight: 800; }
        .table tbody tr {
            transition: background-color 0.2s ease;
        }
        .table tbody tr:hover {
            background-color: rgba(0, 0, 0, 0.015);
        }
    </style>
}