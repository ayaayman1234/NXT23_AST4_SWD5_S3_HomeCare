@model IEnumerable<NursingCarePlatform.Web.Models.Complaint>

@{
    ViewData["Title"] = "Complaints";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold text-danger">
            Complaints Management
        </h2>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-bordered table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Patient</th>

                        <th>Nurse</th>

                        <th>Title</th>

                        <th>Description</th>

                        <th>Status</th>

                        <th>Date</th>

                        <th width="220">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var complaint in Model)
                    {
                        <tr>

                            <td>
                                @(complaint.Patient?.User != null
                                    ? complaint.Patient.User.FirstName + " " + complaint.Patient.User.LastName
                                    : "-")
                            </td>

                            <td>
                                @(complaint.Nurse?.User != null
                                    ? complaint.Nurse.User.FirstName + " " + complaint.Nurse.User.LastName
                                    : "-")
                            </td>

                            <td>

                                <strong>@complaint.Title</strong>

                            </td>

                            <td>

                                @complaint.Description

                            </td>

                            <td>

                                @if (complaint.Status == "Open")
                                {
                                    <span class="badge bg-warning text-dark">
                                        Open
                                    </span>
                                }
                                else if (complaint.Status == "Resolved")
                                {
                                    <span class="badge bg-success">
                                        Resolved
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Closed
                                    </span>
                                }

                            </td>

                            <td>

                                @complaint.CreatedAt.ToString("dd/MM/yyyy")

                            </td>

                            <td>

                                @if (complaint.Status == "Open")
                                {
                                    <a asp-action="Resolve"
                                           asp-route-id="@complaint.Id"
                                           class="btn btn-success btn-sm">

                                        Resolve

                                    </a>

                                    <a asp-action="Close"
                                           asp-route-id="@complaint.Id"
                                           class="btn btn-danger btn-sm">

                                        Close

                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        No Actions
                                    </span>
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>