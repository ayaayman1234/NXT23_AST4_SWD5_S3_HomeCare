@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->

<section class="hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <h1 class="display-4 fw-bold">

                    Professional Nursing Care
                    <span class="text-primary">
                        At Your Home
                    </span>

                </h1>

                <p class="lead mt-4">

                    Find trusted nurses, request home healthcare services,
                    and receive professional medical care with ease.

                </p>

                <div class="mt-4">

                    <a asp-controller="Account"
                           asp-action="Register"
                           class="btn btn-primary btn-lg me-3">

                        Get Started

                    </a>

                    <a asp-controller="Home"
                           asp-action="Services"
                           class="btn btn-outline-primary btn-lg">

                        Our Services

                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img src="~/images/nurse.jpg"
                     class="img-fluid rounded-4 shadow-lg hero-image"
                     alt="Nurse" />

            </div>

        </div>

    </div>

</section>

<!-- Statistics -->

<section class="py-5 bg-light">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <h2 class="text-primary fw-bold">

                    500+

                </h2>

                <p>Professional Nurses</p>

            </div>

            <div class="col-md-3">

                <h2 class="text-success fw-bold">

                    2000+

                </h2>

                <p>Patients Served</p>

            </div>

            <div class="col-md-3">

                <h2 class="text-danger fw-bold">

                    24/7

                </h2>

                <p>Emergency Support</p>

            </div>

            <div class="col-md-3">

                <h2 class="text-warning fw-bold">

                    99%

                </h2>

                <p>Satisfaction Rate</p>

            </div>

        </div>

    </div>

</section>
<section class="py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2 class="fw-bold">
                Our Services
            </h2>

            <p class="text-muted">

                Professional home healthcare services tailored to your needs.

            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card service-card h-100">

                    <div class="card-body text-center">

                        <i class="fa-solid fa-user-nurse service-icon"></i>

                        <h4 class="mt-3">

                            Home Nursing

                        </h4>

                        <p>

                            Qualified nurses provide comprehensive medical care at home.

                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card service-card h-100">

                    <div class="card-body text-center">

                        <i class="fa-solid fa-syringe service-icon"></i>

                        <h4 class="mt-3">

                            Injections

                        </h4>

                        <p>

                            Safe medication administration by licensed nurses.

                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card service-card h-100">

                    <div class="card-body text-center">

                        <i class="fa-solid fa-bed service-icon"></i>

                        <h4 class="mt-3">

                            Elderly Care

                        </h4>

                        <p>

                            Personalized daily care for elderly patients.

                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>
<section class="bg-light py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2>

                Why Choose Us

            </h2>

        </div>

        <div class="row">

            <div class="col-md-3 text-center">

                <i class="fa-solid fa-shield-heart feature-icon"></i>

                <h5 class="mt-3">

                    Trusted Nurses

                </h5>

            </div>

            <div class="col-md-3 text-center">

                <i class="fa-solid fa-clock feature-icon"></i>

                <h5 class="mt-3">

                    24/7 Service

                </h5>

            </div>

            <div class="col-md-3 text-center">

                <i class="fa-solid fa-house-medical feature-icon"></i>

                <h5 class="mt-3">

                    Home Visits

                </h5>

            </div>

            <div class="col-md-3 text-center">

                <i class="fa-solid fa-star feature-icon"></i>

                <h5 class="mt-3">

                    High Quality

                </h5>

            </div>

        </div>

    </div>

</section>
<section class="py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h2>

                How It Works

            </h2>

        </div>

        <div class="row text-center">

            <div class="col-md-4">

                <div class="step-number">

                    1

                </div>

                <h4>

                    Register

                </h4>

            </div>

            <div class="col-md-4">

                <div class="step-number">

                    2

                </div>

                <h4>

                    Request Care

                </h4>

            </div>

            <div class="col-md-4">

                <div class="step-number">

                    3

                </div>

                <h4>

                    Get Service

                </h4>

            </div>

        </div>

    </div>

</section>
<section class="bg-primary text-white text-center py-5">

    <div class="container">

        <h2>

            Need Professional Nursing Care?

        </h2>

        <p class="lead">

            Register now and connect with experienced nurses.

        </p>

        <a asp-controller="Account"
               asp-action="Register"
               class="btn btn-light btn-lg">

            Register Now

        </a>

    </div>

</section>