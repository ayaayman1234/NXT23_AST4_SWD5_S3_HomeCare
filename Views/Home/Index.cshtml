@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->

<section class="hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <h1 class="display-4 mb-4">

                    Professional Nursing Care
                    <br />
                    At Your Home

                </h1>

                <p class="mb-4">

                    HomeCare connects patients with trusted and qualified nurses
                    to receive professional healthcare services from the comfort
                    of their homes.

                </p>

                <a asp-controller="Account"
                       asp-action="Register"
                       class="btn btn-primary btn-lg">

                    Get Started

                </a>

            </div>

            <div class="col-lg-6 text-center">

                <img src="~/images/nurse.jpg"
                     class="hero-image"
                     alt="Nurse" />

            </div>

        </div>

    </div>

</section>

<!-- About -->

<section class="py-5">

    <div class="container text-center">

        <h2 class="fw-bold mb-4">

            About HomeCare

        </h2>

        <p class="lead">

            HomeCare is an online healthcare platform that allows patients
            to easily find experienced nurses for home visits, long-term care,
            emergency assistance, and professional nursing services.

        </p>

    </div>

</section>

<!-- Services -->

<section class="py-5 bg-light">

    <div class="container">

        <h2 class="text-center fw-bold mb-5">

            Our Services

        </h2>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card service-card p-4 text-center h-100">

                    <i class="bi bi-heart-pulse service-icon"></i>

                    <h4 class="mt-3">

                        Home Nursing

                    </h4>

                    <p>

                        Professional nurses for daily healthcare.

                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card service-card p-4 text-center h-100">

                    <i class="bi bi-hospital service-icon"></i>

                    <h4 class="mt-3">

                        Medical Follow-up

                    </h4>

                    <p>

                        Continuous monitoring of patient conditions.

                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card service-card p-4 text-center h-100">

                    <i class="bi bi-capsule-pill service-icon"></i>

                    <h4 class="mt-3">

                        Medication Support

                    </h4>

                    <p>

                        Safe medication administration and follow-up.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- Why Choose Us -->

<section class="py-5">

    <div class="container">

        <h2 class="text-center fw-bold mb-5">

            Why Choose Us?

        </h2>

        <div class="row text-center">

            <div class="col-md-4">

                <i class="bi bi-person-check feature-icon"></i>

                <h4 class="mt-3">

                    Verified Nurses

                </h4>

                <p>

                    Every nurse is verified before joining.

                </p>

            </div>

            <div class="col-md-4">

                <i class="bi bi-clock-history feature-icon"></i>

                <h4 class="mt-3">

                    24/7 Support

                </h4>

                <p>

                    Available whenever you need help.

                </p>

            </div>

            <div class="col-md-4">

                <i class="bi bi-shield-check feature-icon"></i>

                <h4 class="mt-3">

                    Safe & Secure

                </h4>

                <p>

                    Secure communication and trusted healthcare.

                </p>

            </div>

        </div>

    </div>

</section>

<!-- How It Works -->

<section class="py-5 bg-light">

    <div class="container">

        <h2 class="text-center fw-bold mb-5">

            How It Works

        </h2>

        <div class="row text-center">

            <div class="col-md-4">

                <div class="step-number">

                    1

                </div>

                <h5 class="mt-3">

                    Register

                </h5>

                <p>

                    Create your account.

                </p>

            </div>

            <div class="col-md-4">

                <div class="step-number">

                    2

                </div>

                <h5 class="mt-3">

                    Choose Nurse

                </h5>

                <p>

                    Find the best qualified nurse.

                </p>

            </div>

            <div class="col-md-4">

                <div class="step-number">

                    3

                </div>

                <h5 class="mt-3">

                    Receive Care

                </h5>

                <p>

                    Get professional healthcare at home.

                </p>

            </div>

        </div>

    </div>

</section>

<!-- Contact -->

<section class="py-5">

    <div class="container text-center">

        <h2 class="fw-bold mb-4">

            Contact Us

        </h2>

        <p>

            Email:
            support@homecare.com

        </p>

        <p>

            Phone:
            +20 100 000 0000

        </p>

    </div>

</section>