@model NursingCarePlatform.Web.ViewModels.Offer.SendOfferViewModel

@{
    ViewData["Title"] = "Send Offer";
}

<div class="container py-5">

    <div class="card shadow">

        <div class="card-header bg-success text-white">

            <h3 class="mb-0">

                Send Offer

            </h3>

        </div>

        <div class="card-body">
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <form asp-action="SendOffer" method="post">

                <input asp-for="CareRequestId" type="hidden" />

                <div class="mb-3">

                    <label asp-for="ProposedPrice"
                           class="form-label">
                    </label>

                    <input asp-for="ProposedPrice"
                           class="form-control" />

                    <span asp-validation-for="ProposedPrice"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Message"
                           class="form-label">
                    </label>

                    <textarea asp-for="Message"
                              rows="5"
                                  class="form-control">
                    </textarea>

                        <span asp-validation-for="Message"
                              class="text-danger"></span>

                    </div>

                    <button class="btn btn-success">

                        Send Offer

                    </button>

                    <a asp-controller="Nurse"
                           asp-action="AvailableRequests"
                           class="btn btn-secondary">

                        Cancel

                    </a>

                </form>

            </div>

        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }