@model NursingCarePlatform.Web.ViewModels.Admin.AdminNurseViewModel

@{
    ViewData["Title"] = "Nurse Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-person-badge-fill text-success me-2"></i>Nurse Details</h2>
    <a asp-action="Nurses" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back to Nurses
    </a>
</div>

<div class="row g-4">

    <!-- Profile Card -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 text-center">
            <div class="card-body p-4">
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                    {
                        <img src="@Model.ProfilePhoto" class="rounded-circle border" width="110" height="110" style="object-fit:cover;" />
                    }
                    else
                    {
                        <div class="bg-success rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold mx-auto"
                             style="width:110px;height:110px;font-size:40px;">
                            @(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "N")
                        </div>
                    }
                </div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <p class="text-muted small mb-2">@Model.Email</p>
                <div class="d-flex justify-content-center gap-2 mb-3">
                    @if (Model.IsVerified)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Verified</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                    }
                    @if (Model.IsBlocked)
                    {
                        <span class="badge bg-danger"><i class="bi bi-slash-circle me-1"></i>Blocked</span>
                    }
                    else
                    {
                        <span class="badge bg-success"><i class="bi bi-circle-fill me-1"></i>Active</span>
                    }
                </div>

                <!-- Action Buttons -->
                <div class="d-grid gap-2">
                    @if (!Model.IsVerified)
                    {
                        <button class="btn btn-success btn-sm"
                                onclick="confirmAction('Approve nurse @Model.FullName?', '/Admin/ApproveNurse/@Model.Id')">
                            <i class="bi bi-check-circle me-1"></i>Approve Nurse
                        </button>
                        <button class="btn btn-danger btn-sm"
                                onclick="confirmAction('Reject and remove nurse @Model.FullName?', '/Admin/RejectNurse/@Model.Id')">
                            <i class="bi bi-x-circle me-1"></i>Reject Nurse
                        </button>
                    }

                    @if (Model.IsBlocked)
                    {
                        <button class="btn btn-warning btn-sm"
                                onclick="confirmAction('Unblock account for @Model.FullName?', '/Admin/UnBlockNurse/@Model.Id')">
                            <i class="bi bi-unlock me-1"></i>Unblock Account
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-sm"
                                onclick="confirmAction('Block account for @Model.FullName? They will not be able to accept new requests.', '/Admin/BlockNurse/@Model.Id')">
                            <i class="bi bi-lock me-1"></i>Block Account
                        </button>
                    }

                    <a asp-action="NurseDocuments" asp-route-id="@Model.Id" class="btn btn-info btn-sm">
                        <i class="bi bi-file-earmark-text me-1"></i>View Documents
                    </a>

                    <button class="btn btn-outline-danger btn-sm"
                            onclick="confirmAction('Permanently delete nurse @Model.FullName? This cannot be undone!', '/Admin/DeleteNurse/@Model.Id')">
                        <i class="bi bi-trash me-1"></i>Delete Nurse
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Details Card -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white fw-bold">
                <i class="bi bi-info-circle me-2"></i>Nurse Information
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <tbody>
                        <tr>
                            <th width="200" class="bg-light ps-3">Full Name</th>
                            <td class="ps-3">@Model.FullName</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Email</th>
                            <td class="ps-3">@Model.Email</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Phone</th>
                            <td class="ps-3">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Specialization</th>
                            <td class="ps-3">
                                <span class="badge bg-success fs-6">@Model.Specialization</span>
                            </td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Years of Experience</th>
                            <td class="ps-3">@Model.YearsExperience years</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Age</th>
                            <td class="ps-3">@Model.Age</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Gender</th>
                            <td class="ps-3">@(string.IsNullOrEmpty(Model.Gender) ? "-" : Model.Gender)</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Governorate</th>
                            <td class="ps-3">@(string.IsNullOrEmpty(Model.Governorate) ? "-" : Model.Governorate)</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">City</th>
                            <td class="ps-3">@(string.IsNullOrEmpty(Model.City) ? "-" : Model.City)</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Address</th>
                            <td class="ps-3">@(string.IsNullOrEmpty(Model.Address) ? "-" : Model.Address)</td>
                        </tr>
                        <tr>
                            <th class="bg-light ps-3">Availability</th>
                            <td class="ps-3">
                                @if (Model.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Not Available</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-6" id="confirmMessage">Are you sure?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmBtn" href="#" class="btn btn-danger">Confirm</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmAction(message, url) {
            document.getElementById('confirmMessage').textContent = message;
            document.getElementById('confirmBtn').href = url;
            new bootstrap.Modal(document.getElementById('confirmModal')).show();
        }
    </script>
}