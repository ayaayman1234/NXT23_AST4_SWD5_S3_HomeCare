@model NursingCarePlatform.Web.ViewModels.Admin.CreateSubscriptionPlanViewModel
@{
    ViewData["Title"] = "Create Subscription Plan";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="SubscriptionPlans" class="btn btn-outline-secondary btn-sm rounded-pill me-3 px-3">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-plus-circle text-primary me-2"></i>Create Subscription Plan
        </h4>
        <p class="text-muted mb-0 small">Define a new nurse subscription plan with reduced commission.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CreateSubscriptionPlan" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Gold Plan" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Describe what this plan offers..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="MonthlyFee" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">EGP</span>
                                <input asp-for="MonthlyFee" type="number" step="0.01" min="0"
                                       class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="MonthlyFee" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CommissionRate" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="CommissionRate" type="number" step="0.01" min="0" max="1"
                                       class="form-control" placeholder="e.g. 0.05 for 5%" />
                                <span class="input-group-text">rate</span>
                            </div>
                            <div class="form-text">Enter as decimal: 0.05 = 5%, 0 = no commission</div>
                            <span asp-validation-for="CommissionRate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">
                                Active (nurses can subscribe to this plan)
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-check-lg me-2"></i>Create Plan
                        </button>
                        <a asp-action="SubscriptionPlans" class="btn btn-outline-secondary rounded-pill px-4">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
