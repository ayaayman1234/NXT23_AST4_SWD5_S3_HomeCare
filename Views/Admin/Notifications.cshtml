@model List<NursingCarePlatform.Web.ViewModels.Admin.AdminNotificationViewModel>

@{
    ViewData["Title"] = "Notifications";
    var unread = Model.Count(x => !x.IsRead);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-bell-fill text-primary me-2"></i>System Notifications
        </h2>
        @if (unread > 0)
        {
            <span class="badge bg-danger">@unread Unread</span>
        }
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-bell-slash fs-1 d-block mb-3"></i>
        <h5>No notifications found.</h5>
    </div>
}
else
{
    <div class="list-group shadow-sm">
        @foreach (var n in Model)
        {
            <div class="list-group-item list-group-item-action @(n.IsRead ? "" : "list-group-item-light border-start border-4 border-primary")">
                <div class="d-flex w-100 justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            @if (!n.IsRead)
                            {
                                <span class="badge bg-primary">New</span>
                            }
                            <h6 class="mb-0 fw-bold">@n.Title</h6>
                            <span class="badge bg-secondary small">@n.NotificationType</span>
                        </div>
                        <p class="mb-1 text-muted">@n.Message</p>
                        <small class="text-muted">
                            <i class="bi bi-arrow-right-circle me-1"></i>
                            To: <strong>@n.ReceiverType #@n.ReceiverId</strong>
                            &nbsp;|&nbsp;
                            <i class="bi bi-clock me-1"></i>
                            @n.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                        </small>
                    </div>
                    @if (!n.IsRead)
                    {
                        <div class="ms-3">
                            <a asp-action="MarkNotificationRead"
                               asp-route-id="@n.Id"
                               class="btn btn-sm btn-outline-primary"
                               title="Mark as Read">
                                <i class="bi bi-check2"></i>
                            </a>
                        </div>
                    }
                    else
                    {
                        <small class="text-success ms-3" title="Read">
                            <i class="bi bi-check2-all"></i>
                        </small>
                    }
                </div>
            </div>
        }
    </div>

    <div class="mt-3 text-muted small">
        Total: <strong>@Model.Count</strong> &nbsp;|&nbsp;
        Unread: <strong class="text-danger">@unread</strong> &nbsp;|&nbsp;
        Read: <strong class="text-success">@(Model.Count - unread)</strong>
    </div>
}
