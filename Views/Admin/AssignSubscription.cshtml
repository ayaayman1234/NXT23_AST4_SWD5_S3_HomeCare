@{
    ViewData["Title"] = "Assign Subscription";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int nurseId = (int)ViewBag.NurseId;
    var plans = (List<NursingCarePlatform.Web.ViewModels.Admin.AdminSubscriptionPlanViewModel>)ViewBag.Plans;
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="NurseSubscriptions" class="btn btn-outline-secondary btn-sm rounded-pill me-3 px-3">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <h4 class="fw-bold mb-0">
        <i class="bi bi-person-check text-primary me-2"></i>Assign Subscription Plan to Nurse
    </h4>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="AssignSubscription" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="nurseId" value="@nurseId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Subscription Plan</label>
                        <select name="planId" class="form-select" required>
                            <option value="">-- Select a Plan --</option>
                            @foreach (var plan in plans.Where(p => p.IsActive))
                            {
                                <option value="@plan.Id">
                                    @plan.Name – @plan.MonthlyFee.ToString("N0") EGP/mo (@plan.CommissionRateDisplay commission)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Start Date</label>
                            <input type="date" name="startDate" class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">End Date</label>
                            <input type="date" name="endDate" class="form-control"
                                   value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>

                    <div class="alert alert-info border-0 rounded-3 small">
                        <i class="bi bi-info-circle me-2"></i>
                        If the nurse already has an active subscription, it will be cancelled and replaced by the new one.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-check-lg me-2"></i>Assign Plan
                        </button>
                        <a asp-action="NurseSubscriptions" class="btn btn-outline-secondary rounded-pill px-4">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
