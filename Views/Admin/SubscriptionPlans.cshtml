@model List<NursingCarePlatform.Web.ViewModels.Admin.AdminSubscriptionPlanViewModel>
@{
    ViewData["Title"] = "Subscription Plans";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-credit-card-2-front text-primary me-2"></i>Subscription Plans
        </h4>
        <p class="text-muted mb-0 small">
            Manage nurse subscription plans – reduced commission in exchange for a periodic fee.
        </p>
    </div>
    <a asp-action="CreateSubscriptionPlan" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-plus-lg me-2"></i>New Plan
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center p-5">
        <i class="bi bi-credit-card text-muted" style="font-size:3rem;"></i>
        <h5 class="mt-3 text-muted">No subscription plans yet</h5>
        <p class="text-secondary small">Create a plan to allow nurses to subscribe for reduced commission rates.</p>
        <a asp-action="CreateSubscriptionPlan" class="btn btn-outline-primary mt-2 rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>Create First Plan
        </a>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        @foreach (var plan in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100 @(plan.IsActive ? "" : "opacity-75")">
                    <div class="card-header border-0 bg-transparent pt-4 px-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">@plan.Name</h5>
                            @if (plan.IsActive)
                            {
                                <span class="badge bg-success rounded-pill px-3">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3">Inactive</span>
                            }
                        </div>
                    </div>
                    <div class="card-body px-4">
                        <p class="text-muted small mb-3">@(string.IsNullOrEmpty(plan.Description) ? "No description." : plan.Description)</p>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="bg-light rounded-3 p-3 text-center">
                                    <div class="fw-bold text-primary fs-5">@plan.MonthlyFee.ToString("N0") EGP</div>
                                    <small class="text-muted">Monthly Fee</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded-3 p-3 text-center">
                                    <div class="fw-bold text-success fs-5">@plan.CommissionRateDisplay</div>
                                    <small class="text-muted">Commission Rate</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center text-muted small mb-3">
                            <i class="bi bi-people me-2"></i>
                            <strong class="me-1">@plan.ActiveSubscribersCount</strong> active subscriber(s)
                        </div>

                        <small class="text-muted">Created @plan.CreatedAt.ToString("dd MMM yyyy")</small>
                    </div>
                    <div class="card-footer bg-transparent border-0 px-4 pb-4">
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="EditSubscriptionPlan" asp-route-id="@plan.Id"
                               class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <a asp-action="ToggleSubscriptionPlan" asp-route-id="@plan.Id"
                               class="btn btn-outline-@(plan.IsActive ? "warning" : "success") btn-sm rounded-pill px-3">
                                <i class="bi bi-toggle-@(plan.IsActive ? "on" : "off") me-1"></i>
                                @(plan.IsActive ? "Deactivate" : "Activate")
                            </a>
                            <a asp-action="DeleteSubscriptionPlan" asp-route-id="@plan.Id"
                               class="btn btn-outline-danger btn-sm rounded-pill px-3"
                               onclick="return confirm('Delete this plan? This cannot be undone.')">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header border-0 bg-white py-3 px-4">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-list-ul me-2 text-primary"></i>All Plans Summary
            </h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3">Plan Name</th>
                            <th>Monthly Fee</th>
                            <th>Commission Rate</th>
                            <th>Active Subscribers</th>
                            <th>Status</th>
                            <th class="px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plan in Model)
                        {
                            <tr>
                                <td class="px-4 fw-semibold">@plan.Name</td>
                                <td>@plan.MonthlyFee.ToString("N0") EGP/mo</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">
                                        @plan.CommissionRateDisplay
                                    </span>
                                </td>
                                <td>@plan.ActiveSubscribersCount</td>
                                <td>
                                    @if (plan.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="px-4">
                                    <a asp-action="EditSubscriptionPlan" asp-route-id="@plan.Id"
                                       class="btn btn-outline-primary btn-sm rounded-pill px-2 me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="NurseSubscriptions"
                                       class="btn btn-outline-info btn-sm rounded-pill px-2">
                                        <i class="bi bi-people"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
