@model NursingCarePlatform.Web.ViewModels.Admin.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-lock-fill me-2"></i>Change Password
                </h5>
            </div>
            <div class="card-body p-4">

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" style="display:none;"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold">
                            <i class="bi bi-key me-1 text-warning"></i>Current Password
                        </label>
                        <input asp-for="CurrentPassword"
                               type="password"
                               class="form-control"
                               placeholder="Enter current password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">
                            <i class="bi bi-lock me-1 text-primary"></i>New Password
                        </label>
                        <input asp-for="NewPassword"
                               type="password"
                               class="form-control"
                               placeholder="Enter new password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">
                            <i class="bi bi-lock-fill me-1 text-success"></i>Confirm New Password
                        </label>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               placeholder="Confirm new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold">
                            <i class="bi bi-check-circle me-1"></i> Change Password
                        </button>
                        <a asp-action="Profile" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        // Show validation summary if it has errors
        var summary = document.querySelector('[data-valmsg-summary]');
        if (summary && summary.querySelectorAll('li').length > 0) {
            summary.style.display = 'block';
        }
    </script>
}
