@model IEnumerable<NursingCarePlatform.Web.Models.Nurse>

@{
    ViewData["Title"] = "Pending Nurses";
}

<div class="container py-5">

    <h2 class="mb-4">
        Pending Nurses
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No pending nurses.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover">

            <thead class="table-dark">

                <tr>

                    <th>Name</th>

                    <th>Email</th>

                    <th>Specialization</th>

                    <th>Experience</th>

                    <th width="220">
                        Actions
                    </th>

                </tr>

            </thead>

            <tbody>

                @foreach (var nurse in Model)
                {
                    <tr>

                        <td>
                            @nurse.User.FirstName @nurse.User.LastName
                        </td>

                        <td>
                            @nurse.User.Email
                        </td>

                        <td>
                            @nurse.Specialization
                        </td>

                        <td>
                            @nurse.YearsExperience Years
                        </td>

                        <td>

                            <a asp-action="ApproveNurse"
                               asp-route-id="@nurse.Id"
                               class="btn btn-success btn-sm">

                                Approve

                            </a>

                            <a asp-action="RejectNurse"
                               asp-route-id="@nurse.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Reject this nurse?')">

                                Reject

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>
    }

</div>