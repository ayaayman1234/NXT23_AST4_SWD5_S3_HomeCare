@model IEnumerable<NursingCarePlatform.Web.ViewModels.Admin.AdminComplaintViewModel>

@{
    ViewData["Title"] = "Complaints";
    var filter = Context.Request.Query["status"].ToString();
    var search = Context.Request.Query["search"].ToString();

    var filtered = Model.AsEnumerable();
    if (!string.IsNullOrEmpty(search))
        filtered = filtered.Where(c => c.PatientName.Contains(search, StringComparison.OrdinalIgnoreCase)
                                    || c.NurseName.Contains(search, StringComparison.OrdinalIgnoreCase)
                                    || c.Title.Contains(search, StringComparison.OrdinalIgnoreCase));
    if (!string.IsNullOrEmpty(filter))
        filtered = filtered.Where(c => c.Status.Equals(filter, StringComparison.OrdinalIgnoreCase));

    var list = filtered.ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-chat-left-dots text-danger me-2"></i>Complaints Management</h2>
        <small class="text-muted">@list.Count of @Model.Count() complaints shown</small>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Dashboard
    </a>
</div>

<!-- Search + Filter -->
<form method="get" class="card shadow-sm mb-4 border-0">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold small">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@search"
                           class="form-control" placeholder="Search by patient, nurse, or title..." />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Filter by Status</label>
                <select name="status" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty(filter))">All Statuses</option>
                    <option value="Open" selected="@(filter == "Open")">Open</option>
                    <option value="Resolved" selected="@(filter == "Resolved")">Resolved</option>
                    <option value="Rejected" selected="@(filter == "Rejected")">Rejected</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Complaints" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

@if (!list.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-chat-square-text-slash fs-1 d-block mb-2"></i>
        <h5>No complaints found.</h5>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th width="50">#</th>
                            <th>Patient</th>
                            <th>Nurse</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th width="120" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in list)
                        {
                            <tr>
                                <td class="text-muted small">@item.Id</td>
                                <td>
                                    <i class="bi bi-person text-primary me-1"></i> @item.PatientName
                                </td>
                                <td>
                                    @if (item.NurseName == "-")
                                    {
                                        <span class="text-muted fst-italic">Not specified</span>
                                    }
                                    else
                                    {
                                        <span><i class="bi bi-person-badge text-success me-1"></i> @item.NurseName</span>
                                    }
                                </td>
                                <td class="fw-semibold">@item.Title</td>
                                <td>
                                    @if (item.Status == "Open")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>Open</span>
                                    }
                                    else if (item.Status == "Resolved")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Resolved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-slash-circle me-1"></i>Rejected</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="text-center">
                                    <a asp-action="ComplaintDetails" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small d-flex gap-3">
            <span>Total: <strong>@Model.Count()</strong></span>
            <span class="text-danger">Open: <strong>@Model.Count(c => c.Status == "Open")</strong></span>
            <span class="text-success">Resolved: <strong>@Model.Count(c => c.Status == "Resolved")</strong></span>
            <span class="text-secondary">Rejected: <strong>@Model.Count(c => c.Status == "Rejected")</strong></span>
        </div>
    </div>
}