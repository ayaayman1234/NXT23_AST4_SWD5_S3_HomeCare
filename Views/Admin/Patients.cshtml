@model IEnumerable<NursingCarePlatform.Web.ViewModels.Admin.AdminPatientViewModel>

@{
    ViewData["Title"] = "Patients";
    var filter = Context.Request.Query["filter"].ToString();
    var search = Context.Request.Query["search"].ToString();

    var filtered = Model.AsEnumerable();
    if (!string.IsNullOrEmpty(search))
        filtered = filtered.Where(p => p.FullName.Contains(search, StringComparison.OrdinalIgnoreCase)
                                    || p.Email.Contains(search, StringComparison.OrdinalIgnoreCase));
    if (filter == "blocked") filtered = filtered.Where(p => p.IsBlocked);
    if (filter == "active") filtered = filtered.Where(p => !p.IsBlocked);

    var list = filtered.ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-people-fill text-primary me-2"></i>Patient Management</h2>
        <small class="text-muted">@list.Count of @Model.Count() patients shown</small>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Dashboard
    </a>
</div>

<!-- Search + Filter -->
<form method="get" class="card shadow-sm mb-4 border-0">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold small">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@search"
                           class="form-control" placeholder="Search by name or email..." />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Filter by Status</label>
                <select name="filter" class="form-select">
                    <option value="" selected="@(filter == "")">All Patients</option>
                    <option value="active" selected="@(filter == "active")">Active Only</option>
                    <option value="blocked" selected="@(filter == "blocked")">Blocked Only</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <a asp-action="Patients" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

@if (!list.Any())
{
    <div class="alert alert-info text-center py-4">
        <i class="bi bi-people fs-1 d-block mb-2"></i>
        <h5>No patients found matching your criteria.</h5>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th width="50">#</th>
                            <th>Patient</th>
                            <th>Phone</th>
                            <th>Blood Type</th>
                            <th>Status</th>
                            <th width="280" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in list)
                        {
                            <tr>
                                <td class="text-muted small">@patient.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                                             style="width:38px;height:38px;font-size:14px;flex-shrink:0;">
                                            @(patient.FullName.Length > 0 ? patient.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@patient.FullName</div>
                                            <small class="text-muted">@patient.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@(string.IsNullOrEmpty(patient.PhoneNumber) ? "-" : patient.PhoneNumber)</td>
                                <td>
                                    <span class="badge bg-secondary">@patient.BloodType</span>
                                </td>
                                <td>
                                    @if (patient.IsBlocked)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-slash-circle me-1"></i>Blocked</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="bi bi-circle-fill me-1"></i>Active</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        <a asp-action="PatientDetails" asp-route-id="@patient.Id"
                                           class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="bi bi-eye text-info"></i> Details
                                        </a>

                                        @if (patient.IsBlocked)
                                        {
                                            <button type="button" class="btn btn-sm btn-warning" title="Unblock"
                                                    onclick="confirmAction('Unblock patient @patient.FullName?', '/Admin/UnBlockPatient/@patient.Id')">
                                                <i class="bi bi-unlock"></i> Unblock
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-dark" title="Block"
                                                    onclick="confirmAction('Block patient @patient.FullName? They will not be able to create requests.', '/Admin/BlockPatient/@patient.Id')">
                                                <i class="bi bi-lock"></i> Block
                                            </button>
                                        }

                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Delete Patient"
                                                onclick="confirmAction('Permanently delete patient @patient.FullName? All requests and complaints will be removed!', '/Admin/DeletePatient/@patient.Id')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small d-flex gap-3">
            <span>Total: <strong>@Model.Count()</strong></span>
            <span class="text-success">Active: <strong>@Model.Count(p => !p.IsBlocked)</strong></span>
            <span class="text-danger">Blocked: <strong>@Model.Count(p => p.IsBlocked)</strong></span>
        </div>
    </div>
}

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body fs-6" id="confirmMessage">Are you sure?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a id="confirmBtn" href="#" class="btn btn-danger">Confirm</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmAction(message, url) {
            document.getElementById('confirmMessage').textContent = message;
            document.getElementById('confirmBtn').href = url;
            new bootstrap.Modal(document.getElementById('confirmModal')).show();
        }
    </script>
}