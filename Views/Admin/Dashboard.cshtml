@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold text-primary">
            Admin Dashboard
        </h2>

        <p class="text-muted">
            Welcome Admin
        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card shadow text-center">

                <div class="card-body">

                    <i class="bi bi-people-fill display-3 text-primary"></i>

                    <h5 class="mt-3">
                        Patients
                    </h5>

                    <h2>
                        @ViewBag.TotalPatients
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow text-center">

                <div class="card-body">

                    <i class="bi bi-heart-pulse display-3 text-success"></i>

                    <h5 class="mt-3">
                        Nurses
                    </h5>

                    <h2>
                        @ViewBag.TotalNurses
                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow text-center">

                <div class="card-body">

                    <i class="bi bi-hourglass-split display-3 text-warning"></i>

                    <h5 class="mt-3">
                        Pending Nurses
                    </h5>

                    <h2>
                        @ViewBag.PendingNurses
                    </h2>

                    <a asp-action="PendingNurses"
                           class="btn btn-warning mt-3">
                        View Requests
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>