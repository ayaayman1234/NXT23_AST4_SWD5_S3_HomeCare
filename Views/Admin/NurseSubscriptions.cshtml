@model List<NursingCarePlatform.Web.ViewModels.Admin.AdminNurseSubscriptionViewModel>
@{
    ViewData["Title"] = "Nurse Subscriptions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-person-badge text-primary me-2"></i>Nurse Subscriptions
        </h4>
        <p class="text-muted mb-0 small">View and manage which nurses are subscribed to which plans.</p>
    </div>
    <a asp-action="SubscriptionPlans" class="btn btn-outline-primary rounded-pill px-4">
        <i class="bi bi-credit-card me-2"></i>Manage Plans
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center p-5">
        <i class="bi bi-person-x text-muted" style="font-size:3rem;"></i>
        <h5 class="mt-3 text-muted">No nurse subscriptions yet</h5>
        <p class="text-secondary small">Nurses can be assigned plans from the Nurse Details page.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3">Nurse</th>
                            <th>Plan</th>
                            <th>Monthly Fee</th>
                            <th>Commission Rate</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Status</th>
                            <th class="px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in Model)
                        {
                            <tr class="@(sub.IsCurrentlyActive ? "" : "table-secondary")">
                                <td class="px-4 fw-semibold">@sub.NurseName</td>
                                <td>@sub.PlanName</td>
                                <td>@sub.MonthlyFee.ToString("N0") EGP</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">
                                        @((sub.CommissionRate * 100).ToString("0.##"))%
                                    </span>
                                </td>
                                <td>@sub.StartDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (sub.EndDate < DateTime.Now)
                                    {
                                        <span class="text-danger fw-semibold">@sub.EndDate.ToString("dd MMM yyyy") <i class="bi bi-exclamation-triangle"></i></span>
                                    }
                                    else
                                    {
                                        @sub.EndDate.ToString("dd MMM yyyy")
                                    }
                                </td>
                                <td>
                                    @if (sub.Status == "Active" && sub.EndDate >= DateTime.Now)
                                    {
                                        <span class="badge bg-success rounded-pill">Active</span>
                                    }
                                    else if (sub.Status == "Cancelled")
                                    {
                                        <span class="badge bg-secondary rounded-pill">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill">Expired</span>
                                    }
                                </td>
                                <td class="px-4">
                                    @if (sub.Status == "Active")
                                    {
                                        <a asp-action="CancelSubscription" asp-route-id="@sub.Id"
                                           class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                           onclick="return confirm('Cancel this subscription?')">
                                            <i class="bi bi-x-circle me-1"></i>Cancel
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="AssignSubscription" asp-route-nurseId="@sub.NurseId"
                                           class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                            <i class="bi bi-arrow-repeat me-1"></i>Renew
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
