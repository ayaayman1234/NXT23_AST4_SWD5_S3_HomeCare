@model List<NursingCarePlatform.Web.ViewModels.Admin.AdminRatingViewModel>

@{
    ViewData["Title"] = "Ratings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-star-fill text-warning me-2"></i>Ratings</h2>
    <a asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-star fs-1 d-block mb-3"></i>
        <h5>No ratings yet.</h5>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <span class="fw-bold"><i class="bi bi-list-ul me-2"></i>All Ratings</span>
            <span class="badge bg-dark">@Model.Count Total</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Nurse</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td class="text-muted small">@r.Id</td>
                                <td>
                                    <i class="bi bi-person-circle text-primary me-1"></i>
                                    @r.PatientName
                                </td>
                                <td>
                                    <i class="bi bi-person-badge text-success me-1"></i>
                                    @r.NurseName
                                </td>
                                <td>
                                    <span class="text-warning fw-bold fs-5" title="@r.RatingScore / 5">
                                        @r.Stars
                                    </span>
                                    <small class="text-muted ms-1">(@r.RatingScore/5)</small>
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(r.Comment))
                                    {
                                        <span class="text-muted fst-italic">No comment</span>
                                    }
                                    else
                                    {
                                        <span>@r.Comment</span>
                                    }
                                </td>
                                <td class="text-muted small">@r.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small">
            Total Ratings: <strong>@Model.Count</strong> &nbsp;|&nbsp;
            Average: <strong class="text-warning">
                @(Model.Any() ? Model.Average(x => x.RatingScore).ToString("0.0") : "0.0") ⭐
            </strong>
        </div>
    </div>
}
